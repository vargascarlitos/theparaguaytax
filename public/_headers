# Cache Headers for Static Assets
# Configuración de cache para máximo rendimiento

# Assets de Astro (con hash en el nombre - cache inmutable)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Imágenes optimizadas
/*.webp
  Cache-Control: public, max-age=31536000, immutable

/*.avif
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.jpeg
  Cache-Control: public, max-age=31536000, immutable

# JavaScript y CSS
/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

# HTML (cache corto para permitir actualizaciones)
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate

# Favicon
/favicon.svg
  Cache-Control: public, max-age=86400

# Robots
/robots.txt
  Cache-Control: public, max-age=86400

