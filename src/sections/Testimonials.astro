---
import { getTranslations } from '../i18n/utils';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = getTranslations(lang);

// Testimonios reales (estructura para agregar más fácilmente)
const testimonials = [
  {
    id: 'mohamed',
    name: 'Mohamed Al-Rashid',
    role: 'Software Developer',
    location: 'Dubai, UAE',
    image: '/testimonials/mohamed.jpg', // Placeholder path
    rating: 5,
    text: {
      en: "I moved to Paraguay through TheParaguayTax and it was the best decision for my business. The process was smooth, the team was incredibly helpful, and now I pay zero taxes on my international income. The lifestyle here is amazing too - great food, friendly people, and modern amenities. Highly recommend!",
      es: "Me mudé a Paraguay a través de TheParaguayTax y fue la mejor decisión para mi negocio. El proceso fue fluido, el equipo fue increíblemente útil, y ahora pago cero impuestos sobre mis ingresos internacionales. El estilo de vida aquí es increíble también - excelente comida, gente amable y comodidades modernas. ¡Altamente recomendado!"
    },
    verified: true,
    date: '2024-10-15'
  },
  // Aquí se pueden agregar más testimonios fácilmente
  // {
  //   id: 'cliente2',
  //   name: 'Nombre del Cliente',
  //   role: 'Profesión',
  //   location: 'Ciudad, País',
  //   image: '/testimonials/cliente2.jpg',
  //   rating: 5,
  //   text: {
  //     en: "Texto en inglés",
  //     es: "Texto en español"
  //   },
  //   verified: true,
  //   date: '2024-XX-XX'
  // }
];
---

<section id="testimonials" class="relative bg-gradient-to-br from-slate-50 via-white to-slate-50 py-20 sm:py-24 lg:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-dark mb-6 leading-tight">
        {t.testimonials.title || 'What Our Clients Say'}
      </h2>
      <p class="text-xl sm:text-2xl text-gray-600 max-w-3xl mx-auto">
        {t.testimonials.subtitle || 'Real experiences from real people who chose Paraguay'}
      </p>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-6 xl:gap-8">
      {testimonials.map((testimonial) => (
        <div class="group relative bg-white rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-300 border border-gray-100 overflow-hidden transform hover:-translate-y-1">
          <!-- Verified Badge -->
          {testimonial.verified && (
            <div class="absolute top-4 right-4 bg-green-500 text-white px-3 py-1 rounded-full text-xs font-semibold flex items-center gap-1 shadow-lg">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              Verified
            </div>
          )}

          <div class="p-8">
            <!-- Rating -->
            <div class="flex items-center gap-1 mb-4">
              {Array.from({ length: testimonial.rating }).map((_, i) => (
                <svg key={i} class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            <!-- Testimonial Text -->
            <blockquote class="text-gray-700 text-base leading-relaxed mb-6 italic">
              "{testimonial.text[lang]}"
            </blockquote>

            <!-- Client Info -->
            <div class="flex items-center gap-4">
              <!-- Avatar -->
              <div class="relative">
                <div class="w-12 h-12 rounded-full bg-gradient-to-br from-blue-400 to-purple-500 flex items-center justify-center text-white font-bold text-lg shadow-lg">
                  {testimonial.name.split(' ').map(n => n[0]).join('').substring(0, 2)}
                </div>
                <!-- Online indicator -->
                <div class="absolute -bottom-1 -right-1 w-4 h-4 bg-green-400 border-2 border-white rounded-full"></div>
              </div>

              <!-- Details -->
              <div class="flex-1">
                <h4 class="font-bold text-dark text-lg">{testimonial.name}</h4>
                <p class="text-gray-600 text-sm">{testimonial.role}</p>
                <p class="text-gray-500 text-xs flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  </svg>
                  {testimonial.location}
                </p>
              </div>
            </div>

            <!-- Date -->
            <div class="mt-4 pt-4 border-t border-gray-100">
              <p class="text-xs text-gray-400">
                {new Date(testimonial.date).toLocaleDateString(lang === 'es' ? 'es-ES' : 'en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                })}
              </p>
            </div>
          </div>

          <!-- Hover Effect Border -->
          <div class="absolute inset-0 rounded-3xl bg-gradient-to-r from-blue-500/10 to-purple-500/10 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
        </div>
      ))}
    </div>

    <!-- CTA Section -->
    <div class="text-center mt-16">
      <div class="bg-gradient-to-r from-blue-50 to-purple-50 rounded-3xl p-8 border border-blue-100">
        <h3 class="text-2xl sm:text-3xl font-bold text-dark mb-4">
          {t.testimonials.ctaTitle || 'Join Our Growing Community'}
        </h3>
        <p class="text-lg text-gray-600 mb-6 max-w-2xl mx-auto">
          {t.testimonials.ctaText || 'Ready to start your Paraguayan tax residency journey? Join hundreds of satisfied clients who have simplified their lives.'}
        </p>
        <a
          href="#pricing"
          class="inline-flex items-center px-8 py-4 bg-gradient-to-r from-blue-500 to-purple-600 hover:from-blue-600 hover:to-purple-700 text-white font-bold rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:scale-105"
        >
          {t.testimonials.ctaButton || 'Start Your Journey'}
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
