---
import { getTranslations } from '../i18n/utils';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = getTranslations(lang);

const whatsappUrl = `https://wa.me/595985777252?text=${encodeURIComponent(t.services.whatsappMessage)}`;
---

<section id="services" class="relative bg-white py-16 sm:py-20 lg:py-24">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- WhatsApp Contact Header -->
    <div class="text-center mb-12">
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-[#25D366] hover:bg-[#20BD5C] text-white text-xl sm:text-2xl font-bold px-6 py-3 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:scale-105"
      >
        <svg class="w-6 h-6 sm:w-7 sm:h-7" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z" />
        </svg>
        {t.services.whatsapp} +595 985 777252
      </a>
    </div>

    <!-- Services Cards - Vertical Layout -->
    <div class="space-y-6">
      <!-- Service 1: RUC Inscription -->
      <div class="bg-yellow-400 rounded-2xl p-6 sm:p-8 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div>
            <h3 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-2">
              {t.services.rucInscription.price}
            </h3>
            <p class="text-lg sm:text-xl text-gray-800 font-semibold">
              {t.services.rucInscription.title}
            </p>
          </div>
          <div class="text-right">
            <p class="text-sm sm:text-base text-gray-700 font-medium">
              {t.services.rucInscription.payment}
            </p>
          </div>
        </div>
      </div>

      <!-- Service 2: Tax Certificate -->
      <div class="bg-yellow-400 rounded-2xl p-6 sm:p-8 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div>
            <h3 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-2">
              {t.services.taxCertificate.price}
            </h3>
            <p class="text-lg sm:text-xl text-gray-800 font-semibold">
              {t.services.taxCertificate.title}
            </p>
          </div>
          <div class="text-right">
            <p class="text-sm sm:text-base text-gray-700 font-medium">
              {t.services.taxCertificate.payment}
            </p>
          </div>
        </div>
      </div>

      <!-- Service 3: Monthly IVA -->
      <div class="bg-yellow-400 rounded-2xl p-6 sm:p-8 shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div>
            <h3 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-2">
              {t.services.monthlyIVA.price}
            </h3>
            <p class="text-lg sm:text-xl text-gray-800 font-semibold">
              {t.services.monthlyIVA.title}
            </p>
          </div>
          <div class="text-right">
            <p class="text-sm sm:text-base text-gray-700 font-medium">
              {t.services.monthlyIVA.payment}
            </p>
          </div>
        </div>
      </div>

      <!-- Service 4: Special - IVA for One Year -->
      <div class="special-pulse bg-yellow-400 rounded-2xl p-6 sm:p-8 shadow-2xl border-4 border-yellow-500 relative overflow-hidden">
        <div class="absolute top-0 right-0 bg-red-500 text-white px-4 py-2 rounded-bl-xl font-bold text-sm sm:text-base">
          {t.services.specialIVA.badge}
        </div>
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mt-4">
          <div>
            <h3 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-2">
              {t.services.specialIVA.price}
            </h3>
            <p class="text-lg sm:text-xl text-gray-800 font-semibold">
              {t.services.specialIVA.title}
            </p>
          </div>
          <div class="text-right">
            <p class="text-sm sm:text-base text-gray-700 font-medium">
              {t.services.specialIVA.payment}
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .special-pulse {
    animation: pulse-glow 2s ease-in-out infinite;
  }

  @keyframes pulse-glow {
    0% {
      box-shadow: 0 0 0 0 rgba(234, 179, 8, 0.7), 0 0 0 0 rgba(234, 179, 8, 0.5);
      transform: scale(1);
    }
    50% {
      box-shadow: 0 0 0 15px rgba(234, 179, 8, 0), 0 0 0 30px rgba(234, 179, 8, 0);
      transform: scale(1.03);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(234, 179, 8, 0), 0 0 0 0 rgba(234, 179, 8, 0);
      transform: scale(1);
    }
  }

  .special-pulse:hover {
    animation: pulse-glow 1s ease-in-out infinite;
    transform: scale(1.05);
  }
</style>

