---
import { getImage } from 'astro:assets';
import { getTranslations } from '../i18n/utils';
import PremiumGallery from '../components/PremiumGallery';

import asadoGrill from '../assets/images/premium/asado-grill.png';
import sunsetLake from '../assets/images/premium/sunset-lake.png';
import licensePlates from '../assets/images/premium/license-plates.png';
import church from '../assets/images/premium/church.png';
import kayak from '../assets/images/premium/kayak.png';
import floatingDock from '../assets/images/premium/floating-dock.png';
import sunsetTrees from '../assets/images/premium/sunset-trees.png';
import waterLilies from '../assets/images/premium/water-lilies.png';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = getTranslations(lang);

const whatsappUrl = `https://wa.me/595985777252?text=${encodeURIComponent(t.contact.whatsappMessage)}`;

const optimize = (src: ImageMetadata) => getImage({ src, width: 1200, format: 'webp', quality: 80 });

const [
  asadoGrillOpt,
  sunsetLakeOpt,
  licensePlatesOpt,
  churchOpt,
  kayakOpt,
  floatingDockOpt,
  sunsetTreesOpt,
  waterLiliesOpt,
] = await Promise.all([
  optimize(asadoGrill),
  optimize(sunsetLake),
  optimize(licensePlates),
  optimize(church),
  optimize(kayak),
  optimize(floatingDock),
  optimize(sunsetTrees),
  optimize(waterLilies),
]);

const galleryImages = [
  { src: asadoGrillOpt.src, alt: t.premium.gallery.asado },
  { src: sunsetLakeOpt.src, alt: t.premium.gallery.sunsetLake },
  { src: licensePlatesOpt.src, alt: t.premium.gallery.plates },
  { src: churchOpt.src, alt: t.premium.gallery.church },
  { src: kayakOpt.src, alt: t.premium.gallery.kayak },
  { src: floatingDockOpt.src, alt: t.premium.gallery.dock },
  { src: sunsetTreesOpt.src, alt: t.premium.gallery.sunsetTrees },
  { src: waterLiliesOpt.src, alt: t.premium.gallery.lilies },
];

const features = [
  { icon: '🚐', title: t.premium.highlights.tour.title, description: t.premium.highlights.tour.description },
  { icon: '🔥', title: t.premium.highlights.asado.title, description: t.premium.highlights.asado.description },
  { icon: '🏞️', title: t.premium.highlights.nature.title, description: t.premium.highlights.nature.description },
  { icon: '⭐', title: t.premium.highlights.included.title, description: t.premium.highlights.included.description },
];
---

<section id="premium-plan" class="relative bg-gradient-to-br from-[#1A1A1A] via-[#2a1410] to-[#1A1A1A] py-20 sm:py-24 lg:py-28 overflow-hidden">
  <!-- Decorative gradient blobs -->
  <div class="absolute top-0 left-0 w-96 h-96 bg-[#E64A2E]/20 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
  <div class="absolute bottom-0 right-0 w-96 h-96 bg-[#D52B1E]/20 rounded-full blur-3xl translate-x-1/2 translate-y-1/2"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-12 lg:mb-16">
      <div class="inline-flex items-center gap-2 bg-gradient-to-r from-[#E64A2E] to-[#D43B1F] text-white px-5 py-2 rounded-full text-sm font-bold shadow-lg mb-6">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2l2.39 7.36H22l-6.19 4.5L18.2 22 12 17.27 5.8 22l2.39-8.14L2 9.36h7.61L12 2z" />
        </svg>
        {t.premium.badge}
      </div>
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-6 leading-tight">
        {t.premium.title}
      </h2>
      <p class="text-xl sm:text-2xl text-gray-300 max-w-3xl mx-auto mb-4">
        {t.premium.subtitle}
      </p>
      <p class="text-base sm:text-lg text-gray-400 max-w-3xl mx-auto">
        {t.premium.body}
      </p>
    </div>

    <!-- Two column layout -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-14 items-center mb-12">
      <!-- Left: Features -->
      <div class="order-2 lg:order-1">
        <h3 class="text-2xl sm:text-3xl font-bold text-white mb-6">
          {t.premium.featuresTitle}
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {features.map((feature) => (
            <div class="group bg-white/5 backdrop-blur-sm border border-white/10 hover:border-[#E64A2E]/60 rounded-xl p-4 transition-all duration-300 hover:bg-white/10">
              <div class="text-3xl mb-2">{feature.icon}</div>
              <h4 class="font-bold text-white mb-1">{feature.title}</h4>
              <p class="text-sm text-gray-300 leading-relaxed">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Interactive Gallery -->
      <div class="order-1 lg:order-2">
        <PremiumGallery
          client:load
          images={galleryImages}
          prevLabel={t.premium.gallery.prev}
          nextLabel={t.premium.gallery.next}
        />
        <p class="text-center text-sm text-gray-400 mt-3 italic">
          {t.premium.gallery.caption}
        </p>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center">
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-gradient-to-r from-[#E64A2E] to-[#D43B1F] hover:from-[#D43B1F] hover:to-[#B82C13] text-white text-lg sm:text-xl font-bold px-8 py-4 rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-300 transform hover:scale-105"
      >
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2l2.39 7.36H22l-6.19 4.5L18.2 22 12 17.27 5.8 22l2.39-8.14L2 9.36h7.61L12 2z" />
        </svg>
        {t.premium.cta}
      </a>
    </div>
  </div>
</section>
