---
import { getTranslations } from '../i18n/utils';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = getTranslations(lang);

const wizardId = `tax-wizard-${Math.random().toString(36).slice(2, 11)}`;
---

<section id="accounting" class="relative bg-gradient-to-b from-gray-50 to-white py-16 sm:py-20 lg:py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-12 sm:mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-dark mb-4 leading-tight">
        {t.taxWizard.title}
      </h2>
      <p class="text-lg sm:text-xl text-gray-600 max-w-3xl mx-auto">
        {t.taxWizard.subtitle}
      </p>
    </div>

    <!-- Wizard Container -->
    <div id={wizardId} class="relative">
      <!-- Progress Bar -->
      <div class="mb-8 sm:mb-12">
        <div class="flex justify-between items-center mb-3">
          <span class="text-sm font-medium text-gray-600 wizard-progress-label">
            {t.taxWizard.progressLabel.replace('{current}', '1').replace('{total}', '4')}
          </span>
        </div>
        <div class="relative w-full h-2 bg-gray-200 rounded-full overflow-hidden">
          <div class="wizard-progress-bar absolute top-0 left-0 h-full bg-gradient-to-r from-primary to-primary-600 transition-all duration-500 ease-out" style="width: 25%"></div>
        </div>
      </div>

      <!-- Step 1: Activity Type -->
      <div class="wizard-step" data-step="1">
        <div class="text-center mb-8">
          <h3 class="text-2xl sm:text-3xl font-bold text-dark mb-3">
            {t.taxWizard.step1.title}
          </h3>
          <p class="text-gray-600">
            {t.taxWizard.step1.subtitle}
          </p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6">
          <!-- Services Option -->
          <button
            class="wizard-option group relative bg-white rounded-2xl p-6 sm:p-8 shadow-lg hover:shadow-2xl transition-all duration-300 border-2 border-transparent hover:border-primary focus:outline-none focus:ring-4 focus:ring-primary/20"
            data-choice="services"
            data-step="1"
          >
            <div class="flex flex-col items-center text-center space-y-4">
              <div class="w-16 h-16 sm:w-20 sm:h-20 rounded-full bg-primary/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                <svg class="w-8 h-8 sm:w-10 sm:h-10 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h4 class="text-xl font-bold text-dark mb-2">{t.taxWizard.step1.options.services.title}</h4>
                <p class="text-sm text-gray-600">{t.taxWizard.step1.options.services.description}</p>
              </div>
            </div>
          </button>

          <!-- Merchandise Option -->
          <button
            class="wizard-option group relative bg-white rounded-2xl p-6 sm:p-8 shadow-lg hover:shadow-2xl transition-all duration-300 border-2 border-transparent hover:border-secondary focus:outline-none focus:ring-4 focus:ring-secondary/20"
            data-choice="merchandise"
            data-step="1"
          >
            <div class="flex flex-col items-center text-center space-y-4">
              <div class="w-16 h-16 sm:w-20 sm:h-20 rounded-full bg-secondary/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                <svg class="w-8 h-8 sm:w-10 sm:h-10 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
              </div>
              <div>
                <h4 class="text-xl font-bold text-dark mb-2">{t.taxWizard.step1.options.merchandise.title}</h4>
                <p class="text-sm text-gray-600">{t.taxWizard.step1.options.merchandise.description}</p>
              </div>
            </div>
          </button>

          <!-- Both Option -->
          <button
            class="wizard-option group relative bg-white rounded-2xl p-6 sm:p-8 shadow-lg hover:shadow-2xl transition-all duration-300 border-2 border-transparent hover:border-accent focus:outline-none focus:ring-4 focus:ring-accent/20"
            data-choice="both"
            data-step="1"
          >
            <div class="flex flex-col items-center text-center space-y-4">
              <div class="w-16 h-16 sm:w-20 sm:h-20 rounded-full bg-accent/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                <svg class="w-8 h-8 sm:w-10 sm:h-10 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
              </div>
              <div>
                <h4 class="text-xl font-bold text-dark mb-2">{t.taxWizard.step1.options.both.title}</h4>
                <p class="text-sm text-gray-600">{t.taxWizard.step1.options.both.description}</p>
              </div>
            </div>
          </button>
        </div>
      </div>

      <!-- Step 2: Legal Structure -->
      <div class="wizard-step hidden" data-step="2">
        <div class="text-center mb-8">
          <h3 class="text-2xl sm:text-3xl font-bold text-dark mb-3">
            {t.taxWizard.step2.title}
          </h3>
          <p class="text-gray-600">
            {t.taxWizard.step2.subtitle}
          </p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
          <!-- RUC Option -->
          <button
            class="wizard-option group relative bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 border-2 border-transparent hover:border-primary focus:outline-none focus:ring-4 focus:ring-primary/20"
            data-choice="ruc"
            data-step="2"
          >
            <div class="flex flex-col items-center text-center space-y-4">
              <div class="w-20 h-20 rounded-full bg-primary/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                <svg class="w-10 h-10 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
              <div>
                <h4 class="text-xl font-bold text-dark mb-2">{t.taxWizard.step2.options.ruc.title}</h4>
                <p class="text-sm text-gray-600">{t.taxWizard.step2.options.ruc.description}</p>
              </div>
            </div>
          </button>

          <!-- EAS Option -->
          <button
            class="wizard-option group relative bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 border-2 border-transparent hover:border-secondary focus:outline-none focus:ring-4 focus:ring-secondary/20"
            data-choice="eas"
            data-step="2"
          >
            <div class="flex flex-col items-center text-center space-y-4">
              <div class="w-20 h-20 rounded-full bg-secondary/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                <svg class="w-10 h-10 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
              </div>
              <div>
                <h4 class="text-xl font-bold text-dark mb-2">{t.taxWizard.step2.options.eas.title}</h4>
                <p class="text-sm text-gray-600">{t.taxWizard.step2.options.eas.description}</p>
              </div>
            </div>
          </button>
        </div>

        <!-- Back Button -->
        <div class="flex justify-center mt-8">
          <button
            class="wizard-back-btn px-6 py-3 bg-gray-200 hover:bg-gray-300 text-gray-700 font-semibold rounded-lg transition-colors duration-200 flex items-center space-x-2"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            <span>{t.taxWizard.buttons.back}</span>
          </button>
        </div>
      </div>

      <!-- Step 3: Specific Scenario -->
      <div class="wizard-step hidden" data-step="3">
        <div class="text-center mb-8">
          <h3 class="text-2xl sm:text-3xl font-bold text-dark mb-3 wizard-step3-title">
            {t.taxWizard.step3.titleServices}
          </h3>
          <p class="text-gray-600">
            {t.taxWizard.step3.subtitle}
          </p>
        </div>
        
        <!-- Services Options -->
        <div class="wizard-step3-services grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
          <button
            class="wizard-option group relative bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 border-2 border-transparent hover:border-primary focus:outline-none focus:ring-4 focus:ring-primary/20"
            data-choice="local"
            data-step="3"
          >
            <div class="flex flex-col items-center text-center space-y-4">
              <div class="w-20 h-20 rounded-full bg-primary/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                <svg class="w-10 h-10 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h4 class="text-xl font-bold text-dark mb-2">{t.taxWizard.step3.optionsServices.local.title}</h4>
                <p class="text-sm text-gray-600">{t.taxWizard.step3.optionsServices.local.description}</p>
              </div>
            </div>
          </button>

          <button
            class="wizard-option group relative bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 border-2 border-transparent hover:border-secondary focus:outline-none focus:ring-4 focus:ring-secondary/20"
            data-choice="export"
            data-step="3"
          >
            <div class="flex flex-col items-center text-center space-y-4">
              <div class="w-20 h-20 rounded-full bg-secondary/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                <svg class="w-10 h-10 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h4 class="text-xl font-bold text-dark mb-2">{t.taxWizard.step3.optionsServices.export.title}</h4>
                <p class="text-sm text-gray-600">{t.taxWizard.step3.optionsServices.export.description}</p>
              </div>
            </div>
          </button>
        </div>

        <!-- Merchandise Options -->
        <div class="wizard-step3-merchandise hidden grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
          <button
            class="wizard-option group relative bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 border-2 border-transparent hover:border-primary focus:outline-none focus:ring-4 focus:ring-primary/20"
            data-choice="localForeign"
            data-step="3"
          >
            <div class="flex flex-col items-center text-center space-y-4">
              <div class="w-20 h-20 rounded-full bg-primary/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                <svg class="w-10 h-10 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                </svg>
              </div>
              <div>
                <h4 class="text-xl font-bold text-dark mb-2">{t.taxWizard.step3.optionsMerchandise.localForeign.title}</h4>
                <p class="text-sm text-gray-600">{t.taxWizard.step3.optionsMerchandise.localForeign.description}</p>
              </div>
            </div>
          </button>

          <button
            class="wizard-option group relative bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 border-2 border-transparent hover:border-secondary focus:outline-none focus:ring-4 focus:ring-secondary/20"
            data-choice="crypto"
            data-step="3"
          >
            <div class="flex flex-col items-center text-center space-y-4">
              <div class="w-20 h-20 rounded-full bg-secondary/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                <svg class="w-10 h-10 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h4 class="text-xl font-bold text-dark mb-2">{t.taxWizard.step3.optionsMerchandise.crypto.title}</h4>
                <p class="text-sm text-gray-600">{t.taxWizard.step3.optionsMerchandise.crypto.description}</p>
              </div>
            </div>
          </button>
        </div>

        <!-- Back Button -->
        <div class="flex justify-center mt-8">
          <button
            class="wizard-back-btn px-6 py-3 bg-gray-200 hover:bg-gray-300 text-gray-700 font-semibold rounded-lg transition-colors duration-200 flex items-center space-x-2"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            <span>{t.taxWizard.buttons.back}</span>
          </button>
        </div>
      </div>

      <!-- Step 4: Results (will be populated dynamically) -->
      <div class="wizard-step hidden" data-step="4">
        <div class="wizard-results">
          <!-- Results will be inserted here by JavaScript -->
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ wizardId, t }}>
  (function() {
    const wizard = document.getElementById(wizardId);
    if (!wizard) return;

    // State
    const state = {
      currentStep: 1,
      selections: {
        activity: null,
        structure: null,
        scenario: null
      }
    };

    // Elements
    const steps = wizard.querySelectorAll('.wizard-step');
    const progressBar = wizard.querySelector('.wizard-progress-bar');
    const progressLabel = wizard.querySelector('.wizard-progress-label');
    const options = wizard.querySelectorAll('.wizard-option');
    const backButtons = wizard.querySelectorAll('.wizard-back-btn');

    // Navigation Functions
    function showStep(stepNumber) {
      steps.forEach((step, index) => {
        if (index + 1 === stepNumber) {
          step.classList.remove('hidden');
          step.classList.add('animate-fade-in');
        } else {
          step.classList.add('hidden');
          step.classList.remove('animate-fade-in');
        }
      });

      // Update progress
      const progress = (stepNumber / 4) * 100;
      progressBar.style.width = `${progress}%`;
      progressLabel.textContent = t.taxWizard.progressLabel
        .replace('{current}', stepNumber.toString())
        .replace('{total}', '4');

      state.currentStep = stepNumber;
    }

    function nextStep() {
      if (state.currentStep < 4) {
        showStep(state.currentStep + 1);
      }
    }

    function prevStep() {
      if (state.currentStep > 1) {
        showStep(state.currentStep - 1);
      }
    }

    // Handle option selection
    options.forEach(option => {
      option.addEventListener('click', () => {
        const step = parseInt(option.dataset.step);
        const choice = option.dataset.choice;

        if (step === 1) {
          state.selections.activity = choice;
          updateStep3ForActivity();
          nextStep();
        } else if (step === 2) {
          state.selections.structure = choice;
          // For EAS, skip step 3
          if (choice === 'eas') {
            state.selections.scenario = 'eas';
            showResults();
            showStep(4);
          } else {
            nextStep();
          }
        } else if (step === 3) {
          state.selections.scenario = choice;
          showResults();
          nextStep();
        }
      });
    });

    // Back button handlers
    backButtons.forEach(btn => {
      btn.addEventListener('click', prevStep);
    });

    // Update Step 3 based on activity selection
    function updateStep3ForActivity() {
      const step3Title = wizard.querySelector('.wizard-step3-title');
      const servicesOptions = wizard.querySelector('.wizard-step3-services');
      const merchandiseOptions = wizard.querySelector('.wizard-step3-merchandise');

      if (state.selections.activity === 'services') {
        step3Title.textContent = t.taxWizard.step3.titleServices;
        servicesOptions.classList.remove('hidden');
        merchandiseOptions.classList.add('hidden');
      } else if (state.selections.activity === 'merchandise') {
        step3Title.textContent = t.taxWizard.step3.titleMerchandise;
        servicesOptions.classList.add('hidden');
        merchandiseOptions.classList.remove('hidden');
      } else {
        step3Title.textContent = t.taxWizard.step3.titleBoth;
        servicesOptions.classList.remove('hidden');
        merchandiseOptions.classList.add('hidden');
      }
    }

    // Show results based on selections
    function showResults() {
      const resultsContainer = wizard.querySelector('.wizard-results');
      const { activity, structure, scenario } = state.selections;

      let structureKey, taxes, obligations, notes;

      // Determine structure and taxes
      if (structure === 'eas') {
        structureKey = 'easEntity';
        taxes = [
          t.taxWizard.result.taxes.iva,
          t.taxWizard.result.taxes.ireSimple,
          t.taxWizard.result.taxes.idu
        ];
        obligations = [
          t.taxWizard.result.obligations.electronicInvoice,
          t.taxWizard.result.obligations.monthlyVAT,
          t.taxWizard.result.obligations.annualIncome,
          t.taxWizard.result.obligations.balanceSheet,
          t.taxWizard.result.obligations.assembly,
          t.taxWizard.result.obligations.dgpeyjbf,
          t.taxWizard.result.obligations.renewalMipymes
        ];
        notes = [
          t.taxWizard.result.notes.iduOnlyDistribution,
          t.taxWizard.result.notes.easRequirements
        ];
      } else if (activity === 'services' && scenario === 'local') {
        structureKey = 'rucServicesLocal';
        taxes = [
          t.taxWizard.result.taxes.iva,
          t.taxWizard.result.taxes.irp
        ];
        obligations = [
          t.taxWizard.result.obligations.electronicInvoice,
          t.taxWizard.result.obligations.monthlyVAT,
          t.taxWizard.result.obligations.annualIncome,
          t.taxWizard.result.obligations.purchases
        ];
        notes = [];
      } else if (activity === 'services' && scenario === 'export') {
        structureKey = 'rucServicesExport';
        taxes = [
          t.taxWizard.result.taxes.ivaExempt,
          t.taxWizard.result.taxes.irpExempt
        ];
        obligations = [
          t.taxWizard.result.obligations.electronicInvoice,
          t.taxWizard.result.obligations.monthlyVAT,
          t.taxWizard.result.obligations.purchases
        ];
        notes = [
          t.taxWizard.result.notes.exportExempt
        ];
      } else if (activity === 'merchandise' && scenario === 'localForeign') {
        structureKey = 'rucMerchandiseLocal';
        taxes = [
          t.taxWizard.result.taxes.iva,
          t.taxWizard.result.taxes.ireSimple
        ];
        obligations = [
          t.taxWizard.result.obligations.electronicInvoice,
          t.taxWizard.result.obligations.monthlyVAT,
          t.taxWizard.result.obligations.annualIncome,
          t.taxWizard.result.obligations.purchases
        ];
        notes = [
          t.taxWizard.result.notes.ireSwitchThreshold
        ];
      } else if (activity === 'merchandise' && scenario === 'crypto') {
        structureKey = 'rucMerchandiseCrypto';
        taxes = [
          t.taxWizard.result.taxes.ivaExempt,
          t.taxWizard.result.taxes.ireSimple
        ];
        obligations = [
          t.taxWizard.result.obligations.electronicInvoice,
          t.taxWizard.result.obligations.monthlyVAT,
          t.taxWizard.result.obligations.annualIncome,
          t.taxWizard.result.obligations.purchases
        ];
        notes = [
          t.taxWizard.result.notes.cryptoVATExempt
        ];
      } else {
        // Default for 'both' activity
        structureKey = 'rucServicesLocal';
        taxes = [
          t.taxWizard.result.taxes.iva,
          t.taxWizard.result.taxes.irp
        ];
        obligations = [
          t.taxWizard.result.obligations.electronicInvoice,
          t.taxWizard.result.obligations.monthlyVAT,
          t.taxWizard.result.obligations.annualIncome,
          t.taxWizard.result.obligations.purchases
        ];
        notes = [];
      }

      // Build HTML
      let html = `
        <div class="text-center mb-8">
          <h3 class="text-2xl sm:text-3xl font-bold text-dark mb-3">
            ${t.taxWizard.result.title}
          </h3>
        </div>

        <!-- Structure Info -->
        <div class="bg-gradient-to-br from-primary/10 to-primary/5 rounded-2xl p-6 sm:p-8 mb-6">
          <h4 class="text-lg font-bold text-primary mb-2">${t.taxWizard.result.yourStructure}</h4>
          <p class="text-xl font-semibold text-dark">${t.taxWizard.result.structures[structureKey]}</p>
        </div>

        <!-- Taxes -->
        <div class="bg-white rounded-2xl p-6 sm:p-8 shadow-lg mb-6">
          <h4 class="text-xl font-bold text-dark mb-4 flex items-center">
            <svg class="w-6 h-6 mr-2 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
            ${t.taxWizard.result.applicableTaxes}
          </h4>
          <div class="space-y-4">
            ${taxes.map(tax => `
              <div class="border-l-4 border-primary pl-4">
                <div class="flex justify-between items-start mb-2">
                  <div>
                    <p class="font-bold text-dark">${tax.name}</p>
                    <p class="text-sm text-gray-600">${tax.description}</p>
                    ${tax.details ? `<p class="text-xs text-gray-500 mt-1">${tax.details}</p>` : ''}
                    ${tax.note ? `<p class="text-xs text-amber-600 mt-1 font-medium">${tax.note}</p>` : ''}
                  </div>
                  <div class="text-right ml-4">
                    <p class="text-lg font-bold text-primary">${tax.rate}</p>
                    <p class="text-sm text-gray-500">${tax.frequency}</p>
                  </div>
                </div>
              </div>
            `).join('')}
          </div>
        </div>

        <!-- Obligations -->
        <div class="bg-white rounded-2xl p-6 sm:p-8 shadow-lg mb-6">
          <h4 class="text-xl font-bold text-dark mb-4 flex items-center">
            <svg class="w-6 h-6 mr-2 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            ${t.taxWizard.result.otherObligations}
          </h4>
          <ul class="space-y-2">
            ${obligations.map(obligation => `
              <li class="flex items-start">
                <svg class="w-5 h-5 text-green-500 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700">${obligation}</span>
              </li>
            `).join('')}
          </ul>
        </div>

        ${notes.length > 0 ? `
          <!-- Special Notes -->
          <div class="bg-amber-50 border-l-4 border-amber-400 rounded-r-2xl p-6 mb-6">
            <h4 class="text-lg font-bold text-amber-800 mb-3 flex items-center">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              ${t.taxWizard.result.specialNotes}
            </h4>
            <ul class="space-y-2">
              ${notes.map(note => `
                <li class="text-sm text-amber-900">• ${note}</li>
              `).join('')}
            </ul>
          </div>
        ` : ''}

        <!-- Start Over Button -->
        <div class="text-center">
          <button
            class="wizard-restart-btn inline-flex items-center px-8 py-4 bg-primary hover:bg-primary-600 text-white font-bold rounded-xl transition-all duration-300 transform hover:scale-105 shadow-lg"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
            ${t.taxWizard.buttons.startOver}
          </button>
        </div>
      `;

      resultsContainer.innerHTML = html;

      // Add restart button handler
      const restartBtn = resultsContainer.querySelector('.wizard-restart-btn');
      if (restartBtn) {
        restartBtn.addEventListener('click', restartWizard);
      }
    }

    function restartWizard() {
      state.currentStep = 1;
      state.selections = {
        activity: null,
        structure: null,
        scenario: null
      };
      showStep(1);
    }

    // Initialize
    showStep(1);
  })();
</script>

<style>
  .animate-fade-in {
    animation: fadeIn 0.5s ease-in;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .wizard-option:hover {
    transform: translateY(-4px);
  }

  .wizard-option:active {
    transform: translateY(-2px);
  }
</style>

