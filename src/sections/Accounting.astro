---
import { getTranslations } from '../i18n/utils';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = getTranslations(lang);

const whatsappUrl = `https://wa.me/595985777252?text=${encodeURIComponent(t.contact.whatsappMessage)}`;
---

<section id="accounting-services" class="relative bg-gradient-to-br from-blue-50 via-white to-purple-50 py-20 sm:py-24 lg:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-dark mb-6 leading-tight">
        {t.accounting.title}
      </h2>
      <p class="text-xl sm:text-2xl text-gray-600 max-w-3xl mx-auto">
        {t.accounting.subtitle}
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 lg:gap-8 mb-16">
      <!-- Service 1: RUC Inscription -->
      <div class="relative bg-white rounded-3xl shadow-xl border border-gray-200 overflow-hidden transform hover:scale-105 transition-all duration-300 group flex flex-col min-h-[500px]">
        <div class="p-8 flex-1 flex flex-col">
          <!-- Icon -->
          <div class="flex justify-center mb-6">
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center shadow-lg">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
          </div>

          <!-- Price -->
          <div class="text-center mb-4">
            <div class="text-4xl font-extrabold text-primary mb-1">{t.services.rucInscription.price}</div>
            <div class="text-sm text-gray-600 uppercase tracking-wide">{t.services.rucInscription.payment}</div>
          </div>

          <!-- Title -->
          <h3 class="text-xl font-bold text-dark text-center mb-4">
            {t.services.rucInscription.title}
          </h3>

          <!-- Description -->
          <p class="text-gray-600 text-center text-sm leading-relaxed mb-6">
            {t.accounting.rucDesc}
          </p>

          <!-- Features -->
          <div class="space-y-2 mb-6">
            {t.accounting.rucFeatures.map(feature => (
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm text-gray-700">{feature}</span>
              </div>
            ))}
          </div>

          <!-- CTA Button -->
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="block w-full bg-blue-500 hover:bg-blue-600 text-white font-bold py-3 px-6 rounded-xl text-center transition-colors duration-300 shadow-lg hover:shadow-xl mb-4"
          >
            {t.accounting.getStarted}
          </a>

          <!-- See More Button -->
          <a
            href="/ruc-registration"
            class="block w-full border-2 border-gray-300 hover:border-blue-500 text-gray-700 hover:text-blue-600 font-semibold py-2 px-4 rounded-lg text-center transition-colors duration-300"
          >
            {t.accounting.seeMore}
          </a>
        </div>
      </div>

      <!-- Service 2: Tax Certificate -->
      <div class="relative bg-white rounded-3xl shadow-xl border border-gray-200 overflow-hidden transform hover:scale-105 transition-all duration-300 group flex flex-col min-h-[500px]">
        <div class="p-8 flex-1 flex flex-col">
          <!-- Icon -->
          <div class="flex justify-center mb-6">
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-green-500 to-green-600 flex items-center justify-center shadow-lg">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
          </div>

          <!-- Price -->
          <div class="text-center mb-4">
            <div class="text-4xl font-extrabold text-primary mb-1">{t.services.taxCertificate.price}</div>
            <div class="text-sm text-gray-600 uppercase tracking-wide">{t.services.taxCertificate.payment}</div>
          </div>

          <!-- Title -->
          <h3 class="text-xl font-bold text-dark text-center mb-4">
            {t.services.taxCertificate.title}
          </h3>

          <!-- Description -->
          <p class="text-gray-600 text-center text-sm leading-relaxed mb-6">
            {t.accounting.certDesc}
          </p>

          <!-- Features -->
          <div class="space-y-2 mb-6">
            {t.accounting.certFeatures.map(feature => (
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm text-gray-700">{feature}</span>
              </div>
            ))}
          </div>

          <!-- CTA Button -->
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="block w-full bg-green-500 hover:bg-green-600 text-white font-bold py-3 px-6 rounded-xl text-center transition-colors duration-300 shadow-lg hover:shadow-xl mb-4"
          >
            {t.accounting.getCertificate}
          </a>

          <!-- See More Button -->
          <a
            href="/tax-certificate"
            class="block w-full border-2 border-gray-300 hover:border-green-500 text-gray-700 hover:text-green-600 font-semibold py-2 px-4 rounded-lg text-center transition-colors duration-300"
          >
            {t.accounting.seeMore}
          </a>
        </div>
      </div>

      <!-- Service 3: Monthly IVA -->
      <div class="relative bg-white rounded-3xl shadow-xl border border-gray-200 overflow-hidden transform hover:scale-105 transition-all duration-300 group flex flex-col min-h-[500px]">
        <div class="p-8 flex-1 flex flex-col">
          <!-- Icon -->
          <div class="flex justify-center mb-6">
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-purple-500 to-purple-600 flex items-center justify-center shadow-lg">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3a2 2 0 012-2h2a2 2 0 012 2v4m-6 4v10a2 2 0 002 2h8a2 2 0 002-2V11M9 11h6" />
              </svg>
            </div>
          </div>

          <!-- Price -->
          <div class="text-center mb-4">
            <div class="text-4xl font-extrabold text-primary mb-1">{t.services.monthlyIVA.price}</div>
            <div class="text-sm text-gray-600 uppercase tracking-wide">{t.services.monthlyIVA.payment}</div>
          </div>

          <!-- Title -->
          <h3 class="text-xl font-bold text-dark text-center mb-4">
            {t.services.monthlyIVA.title}
          </h3>

          <!-- Description -->
          <p class="text-gray-600 text-center text-sm leading-relaxed mb-6">
            {t.accounting.ivaDesc}
          </p>

          <!-- Features -->
          <div class="space-y-2 mb-6">
            {t.accounting.ivaFeatures.map(feature => (
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span class="text-sm text-gray-700">{feature}</span>
              </div>
            ))}
          </div>

          <!-- CTA Button -->
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="block w-full bg-purple-500 hover:bg-purple-600 text-white font-bold py-3 px-6 rounded-xl text-center transition-colors duration-300 shadow-lg hover:shadow-xl mb-4"
          >
            {t.accounting.startMonthly}
          </a>

          <!-- See More Button -->
          <a
            href="/monthly-iva-service"
            class="block w-full border-2 border-gray-300 hover:border-purple-500 text-gray-700 hover:text-purple-600 font-semibold py-2 px-4 rounded-lg text-center transition-colors duration-300"
          >
            {t.accounting.seeMore}
          </a>
        </div>
      </div>

      <!-- Service 4: Special IVA One Year -->
      <div class="relative bg-white rounded-3xl shadow-2xl border-2 border-yellow-400 overflow-hidden transform hover:scale-105 transition-all duration-300 group flex flex-col min-h-[500px]">
        <!-- Popular Badge -->
        <div class="absolute -top-1 left-1/2 transform -translate-x-1/2 z-10">
          <div class="bg-gradient-to-r from-yellow-400 to-orange-500 text-dark px-4 py-1.5 rounded-full text-xs font-bold shadow-lg border-2 border-white">
            {t.services.specialIVA.badge}
          </div>
        </div>

        <div class="p-8 pt-12 flex-1 flex flex-col">
          <!-- Icon -->
          <div class="flex justify-center mb-6">
            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-yellow-500 to-orange-500 flex items-center justify-center shadow-lg">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
              </svg>
            </div>
          </div>

          <!-- Price -->
          <div class="text-center mb-4">
            <div class="text-4xl font-extrabold text-primary mb-1">{t.services.specialIVA.price}</div>
            <div class="text-sm text-gray-600 uppercase tracking-wide">{t.services.specialIVA.payment}</div>
          </div>

          <!-- Title -->
          <h3 class="text-xl font-bold text-dark text-center mb-4">
            {t.services.specialIVA.title}
          </h3>

          <!-- Description -->
          <p class="text-gray-600 text-center text-sm leading-relaxed mb-6">
            {t.accounting.specialDesc}
          </p>

          <!-- Features -->
          <div class="space-y-2 mb-6">
            {t.accounting.specialFeatures.map(feature => (
              <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-yellow-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                </svg>
                <span class="text-sm text-gray-700">{feature}</span>
              </div>
            ))}
          </div>

          <!-- CTA Button -->
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="block w-full bg-gradient-to-r from-yellow-400 to-orange-500 hover:from-yellow-500 hover:to-orange-600 text-dark font-bold py-3 px-6 rounded-xl text-center transition-all duration-300 shadow-lg hover:shadow-xl transform hover:scale-105 mb-4"
          >
            {t.accounting.chooseAnnual}
          </a>

          <!-- See More Button -->
          <a
            href="/annual-iva-service"
            class="block w-full border-2 border-gray-300 hover:border-yellow-400 text-gray-700 hover:text-yellow-600 font-semibold py-2 px-4 rounded-lg text-center transition-colors duration-300"
          >
            {t.accounting.seeMore}
          </a>
        </div>
      </div>
    </div>

    <!-- WhatsApp CTA -->
    <div class="text-center">
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-[#25D366] hover:bg-[#20BD5C] text-white text-xl sm:text-2xl lg:text-3xl font-bold px-8 py-5 rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-300 transform hover:scale-105"
      >
        <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z" />
        </svg>
        {t.accounting.contactWhatsapp}
      </a>
    </div>
  </div>
</section>
