---
import { getTranslations } from '../i18n/utils';
import { Image } from 'astro:assets';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = getTranslations(lang);

// Importar imágenes de contacto
import contactSunset from '../assets/images/contact-sunset.png';
import contactFood from '../assets/images/contact-food.png';
import contactCulture from '../assets/images/contact-culture.png';
---

<section id="contact" class="relative bg-gray-50 py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Image Gallery -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-16">
      <div class="relative h-64 rounded-2xl overflow-hidden shadow-xl">
        <Image
          src={contactSunset}
          alt="Paisaje paraguayo"
          width={800}
          height={539}
          class="w-full h-full object-cover"
          loading="lazy"
          format="webp"
          quality={85}
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
      </div>
      <div class="relative h-64 rounded-2xl overflow-hidden shadow-xl">
        <Image
          src={contactFood}
          alt="Comida paraguaya"
          width={800}
          height={539}
          class="w-full h-full object-cover"
          loading="lazy"
          format="webp"
          quality={85}
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
      </div>
      <div class="relative h-64 rounded-2xl overflow-hidden shadow-xl">
        <Image
          src={contactCulture}
          alt="Cultura paraguaya"
          width={800}
          height={539}
          class="w-full h-full object-cover"
          loading="lazy"
          format="webp"
          quality={85}
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="text-center mb-16">
      <h2 class="text-4xl sm:text-5xl font-extrabold text-dark mb-6">
        {t.contact.title}
      </h2>
      <p class="text-2xl sm:text-3xl text-gray-700 mb-8">
        {t.contact.subtitle}
      </p>
      <p class="text-xl text-gray-600 mb-12">
        {t.contact.processText}
      </p>

      <!-- Documents Needed -->
      <div class="max-w-3xl mx-auto bg-white rounded-2xl shadow-xl p-8 mb-12">
        <h3 class="text-2xl font-bold text-dark mb-6">{t.contact.allYouNeed}</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-left">
          <div class="flex items-start gap-3">
            <span class="text-2xl flex-shrink-0">✅</span>
            <span class="text-lg text-gray-700">{t.contact.passport}</span>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-2xl flex-shrink-0">✅</span>
            <span class="text-lg text-gray-700">{t.contact.birthCert}</span>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-2xl flex-shrink-0">✅</span>
            <span class="text-lg text-gray-700">{t.contact.criminalRecord}</span>
          </div>
          <div class="flex items-start gap-3">
            <span class="text-2xl flex-shrink-0">✅</span>
            <span class="text-lg text-gray-700">{t.contact.twoDays}</span>
          </div>
        </div>
      </div>

      <p class="text-2xl font-bold text-primary-700 mb-16">
        {t.contact.weHandle}
      </p>
    </div>

    <!-- WhatsApp CTA -->
    <div class="max-w-2xl mx-auto text-center">
      <a
        href={`https://wa.me/595985777252?text=${t.contact.whatsappMessage}`}
        target="_blank"
        rel="noopener noreferrer"
        class="relative whatsapp-pulse inline-flex items-center gap-4 bg-[#25D366] hover:bg-[#20BD5C] text-white text-2xl font-bold px-12 py-6 rounded-2xl shadow-2xl hover:shadow-3xl transition-all duration-300 transform hover:scale-105"
      >
        <svg class="w-10 h-10" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z" />
        </svg>
        <span>{t.contact.whatsappButton}</span>
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
      <p class="mt-6 text-gray-600 text-lg">
        {t.contact.phone}
      </p>
    </div>
  </div>
</section>

<style>
  @keyframes pulse-ring {
    0% {
      transform: scale(0.8);
      opacity: 1;
    }
    100% {
      transform: scale(1.5);
      opacity: 0;
    }
  }

  .whatsapp-pulse::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    border-radius: 1rem;
    background-color: #25d366;
    animation: pulse-ring 1.5s infinite;
    z-index: -1;
  }
</style>

