---
import { getTranslations } from '../i18n/utils';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = getTranslations(lang);

// Obtener todos los artículos
const articles = [
  t.blog.articles.article1,
  t.blog.articles.article2,
  t.blog.articles.article3,
];

// URLs de artículos
const articleUrls = [
  `/${lang}/blog/facturas-electronicas`,
  `/${lang}/blog/clientes-factura`,
  `/${lang}/blog/eas-business-entity`,
];

// Colores de categorías
const categoryColors: Record<string, string> = {
  'Tax Residency': 'bg-primary/10 text-primary',
  'Residencia Fiscal': 'bg-primary/10 text-primary',
  'Business Setup': 'bg-secondary/10 text-secondary',
  'Configuración de Negocios': 'bg-secondary/10 text-secondary',
  'Taxes': 'bg-accent/10 text-accent',
  'Impuestos': 'bg-accent/10 text-accent',
  'Banking': 'bg-yellow-400/20 text-yellow-700',
  'Banca': 'bg-yellow-400/20 text-yellow-700',
  'Lifestyle': 'bg-green-500/10 text-green-700',
  'Estilo de Vida': 'bg-green-500/10 text-green-700',
  'Cryptocurrency': 'bg-purple-500/10 text-purple-700',
  'Criptomonedas': 'bg-purple-500/10 text-purple-700',
};
---

<section id="blog" class="relative bg-gradient-to-b from-white to-gray-50 py-16 sm:py-20 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-12 sm:mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-dark mb-4 leading-tight">
        {t.blog.title}
      </h2>
      <p class="text-lg sm:text-xl text-gray-600 max-w-3xl mx-auto">
        {t.blog.subtitle}
      </p>
    </div>

    <!-- Blog Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
      {articles.map((article, index) => {
        const categoryColor = categoryColors[article.category] || 'bg-gray-100 text-gray-700';
        return (
          <article class="group bg-white rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 overflow-hidden border border-gray-100 hover:-translate-y-2">
            <!-- Article Image -->
            <div class="relative h-48 overflow-hidden">
              <img
                src={article.image}
                alt={article.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            </div>

            <!-- Content -->
            <div class="p-6">
              <!-- Category Badge -->
              <div class="mb-3">
                <span class={`inline-block px-3 py-1 rounded-full text-xs font-semibold ${categoryColor}`}>
                  {article.category}
                </span>
              </div>

              <!-- Title -->
              <h3 class="text-xl sm:text-2xl font-bold text-dark mb-3 group-hover:text-primary transition-colors duration-300 line-clamp-2">
                {article.title}
              </h3>

              <!-- Excerpt -->
              <p class="text-gray-600 mb-4 line-clamp-3 leading-relaxed">
                {article.excerpt}
              </p>

              <!-- Footer -->
              <div class="flex items-center justify-between pt-4 border-t border-gray-100">
                <span class="text-sm text-gray-500 flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  {t.blog.readTime.replace('{minutes}', article.readTime.toString())}
                </span>
                <a
                  href={articleUrls[index]}
                  class="text-primary font-semibold hover:text-primary-600 transition-colors duration-200 flex items-center gap-1 group-hover:gap-2"
                >
                  {t.blog.readMore}
                  <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

