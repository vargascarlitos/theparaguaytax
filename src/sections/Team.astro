---
import { getTranslations } from '../i18n/utils';
import { Image } from 'astro:assets';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = getTranslations(lang);

// Importar fotos del equipo
import teamOsvaldo from '../assets/images/team-osvaldo.png';
import teamRomina from '../assets/images/team-romina.png';
import teamBeatriz from '../assets/images/team-beatriz.png';
import teamBrenda from '../assets/images/team-brenda.png';
---

<section id="about" class="relative bg-white py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Team -->
    <div class="text-center">
      <h2 class="text-4xl sm:text-5xl font-extrabold text-dark mb-12">{t.team.title}</h2>
      
      <div class="flex flex-wrap justify-center gap-12">
        <div class="text-center">
          <div class="w-32 h-32 sm:w-40 sm:h-40 rounded-full overflow-hidden mx-auto mb-4 shadow-xl ring-4 ring-primary/20">
            <Image
              src={teamOsvaldo}
              alt="Osvaldo - TheParaguayTax Team"
              width={320}
              height={320}
              class="w-full h-full object-cover"
              loading="lazy"
              format="webp"
              quality={85}
            />
          </div>
          <h3 class="text-xl font-bold text-dark">{t.team.osvaldo}</h3>
        </div>

        <div class="text-center">
          <div class="w-32 h-32 sm:w-40 sm:h-40 rounded-full overflow-hidden mx-auto mb-4 shadow-xl ring-4 ring-secondary/20">
            <Image
              src={teamRomina}
              alt="Romina - TheParaguayTax Team"
              width={320}
              height={320}
              class="w-full h-full object-cover"
              loading="lazy"
              format="webp"
              quality={85}
            />
          </div>
          <h3 class="text-xl font-bold text-dark">{t.team.romina}</h3>
        </div>

        <div class="text-center">
          <div class="w-32 h-32 sm:w-40 sm:h-40 rounded-full overflow-hidden mx-auto mb-4 shadow-xl ring-4 ring-primary/20">
            <Image
              src={teamBeatriz}
              alt="Beatriz - TheParaguayTax Team"
              width={320}
              height={320}
              class="w-full h-full object-cover"
              loading="lazy"
              format="webp"
              quality={85}
            />
          </div>
          <h3 class="text-xl font-bold text-dark">{t.team.beatriz}</h3>
        </div>

        <div class="text-center">
          <div class="w-32 h-32 sm:w-40 sm:h-40 rounded-full overflow-hidden mx-auto mb-4 shadow-xl ring-4 ring-secondary/20">
            <Image
              src={teamBrenda}
              alt="Brenda - TheParaguayTax Team"
              width={320}
              height={320}
              class="w-full h-full object-cover"
              loading="lazy"
              format="webp"
              quality={85}
            />
          </div>
          <h3 class="text-xl font-bold text-dark">{t.team.brenda}</h3>
        </div>

      </div>
    </div>
  </div>
</section>

