---
import { getTranslations } from '../i18n/utils';
import { Image } from 'astro:assets';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const t = getTranslations(lang);

// Importar fotos del equipo
import teamCarlos from '../assets/images/team-carlos.png';
import teamBrenda from '../assets/images/team-brenda.png';
import teamLuna from '../assets/images/team-luna.png';
---

<section id="about" class="relative bg-white py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Team -->
    <div class="text-center mb-20">
      <h2 class="text-4xl sm:text-5xl font-extrabold text-dark mb-12">{t.team.title}</h2>
      
      <div class="flex flex-wrap justify-center gap-12">
        <div class="text-center">
          <div class="w-32 h-32 sm:w-40 sm:h-40 rounded-full overflow-hidden mx-auto mb-4 shadow-xl ring-4 ring-primary/20">
            <Image 
              src={teamCarlos}
              alt="Carlos - TheParaguayTax Team"
              width={320}
              height={320}
              class="w-full h-full object-cover"
              loading="lazy"
              format="webp"
              quality={85}
            />
          </div>
          <h3 class="text-xl font-bold text-dark">{t.team.osvaldo}</h3>
        </div>

        <div class="text-center">
          <div class="w-32 h-32 sm:w-40 sm:h-40 rounded-full overflow-hidden mx-auto mb-4 shadow-xl ring-4 ring-secondary/20">
            <Image 
              src={teamBrenda}
              alt="Brenda - TheParaguayTax Team"
              width={320}
              height={320}
              class="w-full h-full object-cover"
              loading="lazy"
              format="webp"
              quality={85}
            />
          </div>
          <h3 class="text-xl font-bold text-dark">{t.team.beatriz}</h3>
        </div>

        <div class="text-center">
          <div class="w-32 h-32 sm:w-40 sm:h-40 rounded-full overflow-hidden mx-auto mb-4 shadow-xl ring-4 ring-accent/20">
            <Image 
              src={teamLuna}
              alt="Luna - TheParaguayTax Team"
              width={320}
              height={320}
              class="w-full h-full object-cover"
              loading="lazy"
              format="webp"
              quality={85}
            />
          </div>
          <h3 class="text-xl font-bold text-dark">{t.team.romina}</h3>
        </div>

        <!-- Placeholder 1 -->
        <div class="text-center">
          <div class="w-32 h-32 sm:w-40 sm:h-40 rounded-full overflow-hidden mx-auto mb-4 shadow-xl ring-4 ring-primary/20 bg-gradient-to-br from-gray-200 to-gray-300 flex items-center justify-center">
            <svg class="w-16 h-16 sm:w-20 sm:h-20 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-dark">{t.team.placeholder1}</h3>
        </div>

        <!-- Placeholder 2 -->
        <div class="text-center">
          <div class="w-32 h-32 sm:w-40 sm:h-40 rounded-full overflow-hidden mx-auto mb-4 shadow-xl ring-4 ring-secondary/20 bg-gradient-to-br from-gray-200 to-gray-300 flex items-center justify-center">
            <svg class="w-16 h-16 sm:w-20 sm:h-20 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-dark">{t.team.placeholder2}</h3>
        </div>

        <!-- Placeholder 3 -->
        <div class="text-center">
          <div class="w-32 h-32 sm:w-40 sm:h-40 rounded-full overflow-hidden mx-auto mb-4 shadow-xl ring-4 ring-accent/20 bg-gradient-to-br from-gray-200 to-gray-300 flex items-center justify-center">
            <svg class="w-16 h-16 sm:w-20 sm:h-20 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-dark">{t.team.placeholder3}</h3>
        </div>
      </div>
    </div>

    <!-- Mobile App Section -->
    <div class="bg-primary rounded-3xl overflow-hidden shadow-2xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center p-8 lg:p-12">
        <!-- Left Content -->
        <div class="text-white">
          <h2 class="text-3xl sm:text-4xl font-extrabold mb-6">
            {t.team.comingSoon}
          </h2>
          
          <p class="text-xl mb-4 leading-relaxed">
            {t.team.appDescription}
          </p>
          
          <p class="text-white mb-8">
            {t.team.appDetails}
          </p>
          
          <div class="flex flex-wrap gap-4">
            <a
              href="https://daseapp.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-3 bg-white text-primary font-bold px-8 py-4 rounded-xl hover:bg-white/90 hover:scale-105 transition-all duration-300 shadow-lg text-lg"
            >
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
              {t.team.visitApp}
            </a>
          </div>
        </div>

        <!-- Right Content - App Mockup -->
        <div class="relative flex justify-center items-center">
          <div class="relative z-10">
            <!-- iPhone Mockup -->
            <div class="relative w-64 h-[32rem] bg-gray-900 rounded-[3rem] shadow-2xl p-3 transform rotate-6 hover:rotate-0 transition-transform duration-500">
              <div class="w-full h-full bg-white rounded-[2.5rem] overflow-hidden">
                <!-- Notch -->
                <div class="h-6 bg-gray-900 rounded-b-3xl mx-auto w-40"></div>
                <!-- App Content Placeholder -->
                <div class="p-4 space-y-4">
                  <div class="flex items-center justify-between">
                    <div class="w-24 h-8 bg-primary/20 rounded-lg"></div>
                    <div class="w-16 h-8 bg-accent/20 rounded-lg"></div>
                  </div>
                  <div class="bg-gradient-to-br from-primary to-accent h-32 rounded-2xl"></div>
                  <div class="space-y-3">
                    <div class="h-12 bg-gray-100 rounded-xl"></div>
                    <div class="h-12 bg-gray-100 rounded-xl"></div>
                    <div class="h-12 bg-gray-100 rounded-xl"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Second Phone (Background) -->
          <div class="absolute left-12 top-8 opacity-60">
            <div class="w-56 h-[28rem] bg-gray-800 rounded-[3rem] shadow-xl p-3 transform -rotate-12">
              <div class="w-full h-full bg-white/50 rounded-[2.5rem]"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

