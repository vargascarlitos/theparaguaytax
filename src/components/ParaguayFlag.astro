---
// Componente SVG de la bandera de Paraguay
// Tres franjas horizontales iguales: roja, blanca y azul
// Colores oficiales: Rojo #D52B1E, Blanco #FFFFFF, Azul #0038A8
---

<svg 
  class="paraguay-flag"
  width="32" 
  height="24" 
  viewBox="0 0 32 24" 
  fill="none" 
  xmlns="http://www.w3.org/2000/svg"
  aria-label="Paraguay flag"
  role="img"
>
  <!-- Franja roja superior -->
  <rect x="0" y="0" width="32" height="8" fill="#D52B1E"/>
  <!-- Franja blanca central -->
  <rect x="0" y="8" width="32" height="8" fill="#FFFFFF"/>
  <!-- Franja azul inferior -->
  <rect x="0" y="16" width="32" height="8" fill="#0038A8"/>
</svg>

<style>
  .paraguay-flag {
    display: inline-block;
    vertical-align: middle;
    flex-shrink: 0;
    width: 1.5rem;
    height: auto;
  }
</style>

